# 用户管理系统 - 环境变量配置
# 🚨 请勿将此文件提交到 Git 仓库！
# 复制为 .env 后填写配置，然后运行: ./scripts/run.sh
#
# 使用方式:
#   cp .env.example .env
#   vi .env              # 填入你的配置
#   ./scripts/run.sh     # 开发模式
#   ./scripts/run.sh prod  # 生产模式
#
# 生产环境必需配置:
#   APP_ENV、SECRET_KEY、ADMIN_PASSWORD、ALICE_PASSWORD
# ============================================================

# 运行环境（production / development）
# 生产模式下强制要求 SECRET_KEY，并启用 SESSION_COOKIE_SECURE
export APP_ENV="production"

# Session 签名密钥（生产环境必须设置）
# 生成命令: python3 -c 'import secrets; print(secrets.token_hex(32))'
export SECRET_KEY="请使用 secrets.token_hex(32) 生成"

# 管理员密码（≥12位，含大小写+数字+特殊字符）
export ADMIN_PASSWORD="请使用密码管理器生成强密码"

# 普通用户密码（≥12位，含大小写+数字+特殊字符）
export ALICE_PASSWORD="请使用密码管理器生成强密码"

# Redis 连接地址（用于限流和渐进延迟计数）
export REDIS_URL="redis://127.0.0.1:6379/0"

# 可选配置
# export FLASK_DEBUG=0
# export FLASK_HTTPS=0
